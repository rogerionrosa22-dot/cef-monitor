name: Monitor Imóveis Caixa

on:
  schedule:
    - cron: '0 10 * * *'   # Diariamente às 7h BRT (10h UTC)
  workflow_dispatch:         # Permite execução manual no GitHub

jobs:
  monitorar:
    runs-on: ubuntu-latest

    steps:
      - name: Checkout repositório
        uses: actions/checkout@v4

      - name: Configurar Python 3.11
        uses: actions/setup-python@v5
        with:
          python-version: '3.11'

      - name: Instalar dependências
        run: pip install requests pandas

      - name: Baixar CSV e filtrar imóveis
        id: filtrar
        run: python scripts/filtrar.py

      - name: Salvar resultados no repositório
        run: |
          git config user.name  "Agente CEF"
          git config user.email "agente@cef-monitor"
          git add docs/imoveis.json docs/ultima_execucao.txt 2>/dev/null || true
          git diff --cached --quiet || git commit -m "🏠 Atualização $(date +'%d/%m/%Y %H:%M BRT')"
          git push
        env:
          GITHUB_TOKEN: ${{ secrets.GITHUB_TOKEN }}

      - name: Notificar WhatsApp se houver novidades
        if: env.NOVOS_COUNT != '0'
        run: python scripts/notificar.py
        env:
          WPP_PHONE:   ${{ secrets.WPP_PHONE }}
          WPP_APIKEY:  ${{ secrets.WPP_APIKEY }}
